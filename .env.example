# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
ALLOWED_CHAT_ID=123456789          # your Telegram chat/user ID (integer)
TELEGRAM_MODE=polling              # polling (local dev) | webhook (production VPS)
WEBHOOK_URL=https://yourdomain.com # required when TELEGRAM_MODE=webhook
WEBHOOK_SECRET=                    # optional Telegram webhook secret token

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=agentzero

# LLM provider
LLM_PROVIDER=openai                # openai | anthropic

# OpenAI (active when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini      # NL write path — low latency
OPENAI_DIGEST_MODEL=gpt-4o         # digest narration — better reasoning

# Anthropic (active when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_CHAT_MODEL=claude-haiku-4-5
ANTHROPIC_DIGEST_MODEL=claude-sonnet-4-6

# Digest config (optional — these are the defaults)
STALL_DAYS_WORK=7
STALL_DAYS_PERSONAL=14
