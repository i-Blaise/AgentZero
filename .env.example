# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
ALLOWED_CHAT_ID=123456789          # your Telegram chat/user ID (integer)
TELEGRAM_MODE=polling              # polling (local dev) | webhook (production VPS)
WEBHOOK_URL=https://yourdomain.com # required when TELEGRAM_MODE=webhook
WEBHOOK_SECRET=                    # optional Telegram webhook secret token

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=agentzero

# LLM provider
LLM_PROVIDER=openai                # openai | anthropic

# OpenAI (active when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini      # NL write path — low latency
OPENAI_DIGEST_MODEL=gpt-4o         # digest narration — better reasoning

# Anthropic (active when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_CHAT_MODEL=claude-haiku-4-5
ANTHROPIC_DIGEST_MODEL=claude-sonnet-4-6

# Digest config (optional — these are the defaults)
STALL_DAYS_WORK=7
STALL_DAYS_PERSONAL=14

# Timezone (reminders, digests, autonomy)
TIMEZONE=Africa/Accra

# Autonomy — proactive heartbeat
# The bot picks the single most-urgent task by its own judgment and nudges about ONE thing
# at a time, spaced by a random gap (min..max) so pings feel spontaneous, not scheduled.
AUTONOMY_ENABLED=true       # master switch
HEARTBEAT_MINUTES=15        # how often it checks state (must be <= NUDGE_MIN_GAP_MINUTES)
QUIET_HOURS_START=21        # no proactive pings from 21:00...
QUIET_HOURS_END=8           # ...until 08:00
NUDGE_MIN_GAP_MINUTES=30    # soonest the next proactive nudge can land after one fires
NUDGE_MAX_GAP_MINUTES=150   # latest it will wait (random pick in between = spontaneous feel)

# Morning digest — daily rundown of what's on your plate
MORNING_DIGEST_ENABLED=true
MORNING_DIGEST_HOUR=8       # 24h local time
MORNING_DIGEST_MINUTE=0

# Evening digest — daily wind-down that tees up tomorrow
EVENING_DIGEST_ENABLED=true
EVENING_DIGEST_HOUR=22     # 24h local time (22:30 = 10:30pm)
EVENING_DIGEST_MINUTE=30

# Job hunter — daily drop of new matching postings (free sources, no API key)
JOB_HUNT_ENABLED=true
JOB_DIGEST_HOUR=9
JOB_DIGEST_MINUTE=0

# Persistent reminders — follow-up cadence until you confirm a reminder is done
REMINDER_FOLLOWUP_MINUTES=90

# Web search / fetch — lets the bot research & read pages from inside the chat.
# web_fetch needs no key. web_search picks a backend by WEB_SEARCH_PROVIDER:
#   auto       — use Tavily if its key is set, else Brave, else keyless DuckDuckGo
#   tavily     — recommended; LLM-friendly, free tier at tavily.com
#   brave      — free tier; key from brave.com/search/api
#   duckduckgo — no key, best-effort (often blocked from a VPS/datacenter IP)
WEB_SEARCH_PROVIDER=auto
TAVILY_API_KEY=                                # free key at tavily.com (recommended for the VPS)
BRAVE_API_KEY=                                 # alternative; free key from brave.com/search/api

# Dashboard API — read-only JSON expense endpoints under /api for an external dashboard.
# DISABLED unless DASHBOARD_API_KEY is set. Callers send it in the X-API-Key header.
DASHBOARD_API_KEY=                              # set a long random secret to enable the API
DASHBOARD_ORIGINS=*                             # comma-separated allowed origins for browser CORS

# Gmail over IMAP — for BACKGROUND scanning (expense receipts), separate from the Google MCP
# (interactive Gmail/Calendar). Needs a Google App Password (Google Account → Security →
# 2-Step Verification → App passwords). Read-only.
GMAIL_IMAP_ENABLED=false
GMAIL_IMAP_USER=you@gmail.com
GMAIL_IMAP_APP_PASSWORD=                        # 16-char Google app password

# Expense tracking — scans payment receipts from the IMAP mailboxes above (Yahoo + Gmail),
# logs them, and sends a weekly spending summary. Manual add_expense works regardless.
EXPENSE_TRACKING_ENABLED=true
RECEIPT_SCAN_HOURS=6
DEFAULT_CURRENCY=GHS                            # used when a receipt's currency is unclear
EXPENSE_SUMMARY_DOW=sun                         # weekly summary day (cron day-of-week)
EXPENSE_SUMMARY_HOUR=18

# Job application tracking — auto-detects application confirmations + employer replies in the
# (Yahoo) inbox, tracks each application's status, and proactively reports changes. Needs Yahoo
# Mail enabled for the auto-scan; manual tracking (track/update) works without it.
JOB_TRACKING_ENABLED=true
APPLICATION_SCAN_HOURS=6        # how often it scans the inbox for application updates
APPLICATION_STALE_DAYS=10       # no reply after this many days → "want to follow up?" nudge

# Yahoo Mail — read-only via IMAP. Generate a Yahoo *app password* (Yahoo Account Security →
# Generate app password), NOT your normal password. Read-only is enforced in code.
YAHOO_MAIL_ENABLED=false
YAHOO_MAIL_USER=you@yahoo.com
YAHOO_MAIL_APP_PASSWORD=                        # 16-char Yahoo app password

# MCP — external platforms (Gmail, Calendar, …). See CONNECT_GOOGLE.md
MCP_ENABLED=false                              # flip to true once the MCP server is running
GOOGLE_MCP_URL=http://127.0.0.1:8001/mcp       # Google Workspace MCP server (streamable-http)
# Exact connected Google account emails (comma-separated) — pinned so the bot uses them
# verbatim and never guesses/truncates (e.g. a .com.gh address).
GOOGLE_ACCOUNTS=menniablaise@gmail.com,blaise.mennia@interactivedigital.com.gh
